{
  "name": "mentorcliq",
  "version": "0.1.0",
  "private": true,
  "description": "O&T Growth Engine with AI navigation assistant.",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build:assistant": "npm run build --prefix frontend",
    "start:backend": "npm run dev --prefix backend",
    "start:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run start:backend\" \"npm run build:assistant -- --watch\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
